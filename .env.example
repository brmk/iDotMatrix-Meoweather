# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Your location (used for weather + day/night detection)
LATITUDE=49.5535
LONGITUDE=25.5948

# ── DEPLOY (only needed for self-hosted RPi deployment) ───────────────────────
APP_IMAGE=ghcr.io/REPLACE_ME/led-matrix-idotmatrix-app:main
SIDECAR_IMAGE=ghcr.io/REPLACE_ME/led-matrix-idotmatrix-sidecar:main
RPI_HOST=pi@raspberrypi.local
RPI_DIR=$HOME/led-matrix

# ── OPTIONAL (defaults shown, uncomment to override) ──────────────────────────
# TZ=Europe/Kiev
# INTERVAL_SECONDS=600
# SIDECAR_URL=http://127.0.0.1:8765
# SCAN_TIMEOUT=15
# DEVICE_NAME_PREFIX=IDM
