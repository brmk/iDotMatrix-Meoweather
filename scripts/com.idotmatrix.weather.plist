<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Unique label — used by launchctl to identify this agent -->
  <key>Label</key>
  <string>com.idotmatrix.weather</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/ihorbarmak/workspace/led-matrix-idotmatrix/scripts/start.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/ihorbarmak/workspace/led-matrix-idotmatrix</string>

  <!-- Start on login and keep alive if the script exits -->
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <!-- Throttle rapid restart loops (seconds) -->
  <key>ThrottleInterval</key>
  <integer>30</integer>

  <!-- Log files (directory must exist; created by install target below) -->
  <key>StandardOutPath</key>
  <string>/Users/ihorbarmak/workspace/led-matrix-idotmatrix/logs/out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/ihorbarmak/workspace/led-matrix-idotmatrix/logs/err.log</string>
</dict>
</plist>
